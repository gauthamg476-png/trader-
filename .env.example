# Email Configuration for Nodemailer
# Gmail SMTP Settings

# Your Gmail address (the email that will send notifications)
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# To generate an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate a new App Password for "Mail"
# 5. Copy the 16-character password and paste it here
EMAIL_PASS=your-app-password-here

# Admin email address (where notifications will be sent)
# If not set, notifications will be sent to EMAIL_USER
ADMIN_EMAIL=admin@thanvitrader.com

# Server Port (optional, defaults to 3001)
PORT=3001
